{
  "name": "smena-platform",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "predev": "npm run build -w @smena/contracts",
    "dev": "concurrently -n api,web -c yellow,cyan \"npm run dev -w @smena/api\" \"npm run dev -w @smena/web\"",
    "predev:api": "npm run build -w @smena/contracts",
    "dev:api": "npm run dev -w @smena/api",
    "predev:web": "npm run build -w @smena/contracts",
    "dev:web": "npm run dev -w @smena/web",
    "build": "npm run build -w @smena/contracts && npm run build -w @smena/api && npm run build -w @smena/web",
    "check": "npm run build -w @smena/contracts && npm run check -w @smena/api && npm run check -w @smena/web",
    "test": "npm run test -w @smena/api",
    "db:migrate": "node --env-file-if-exists=.env apps/api/scripts/migrate.mjs",
    "db:migrate:verify": "node --env-file-if-exists=.env apps/api/scripts/verify-migrations.mjs",
    "db:backup": "node --env-file-if-exists=.env apps/api/scripts/backup.mjs",
    "db:restore:test": "node --env-file-if-exists=.env apps/api/scripts/restore.mjs",
    "db:restore:verify": "node --env-file-if-exists=.env apps/api/scripts/verify-restore.mjs",
    "db:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/postgres-start.ps1",
    "db:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/postgres-status.ps1",
    "db:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/postgres-stop.ps1",
    "prototype:dev": "vite",
    "prototype:build": "vite build",
    "prototype:preview": "vite preview",
    "graphics:export": "node scripts/export-graphics.mjs"
  },
  "dependencies": {
    "@fontsource-variable/commissioner": "^5.2.10",
    "@fontsource/onest": "^5.2.5",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "sharp": "^0.35.3",
    "vite": "^6.0.5"
  }
}
